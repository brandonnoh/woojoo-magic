{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph v2 Iteration Metric",
  "type": "object",
  "required": ["iter", "timestamp", "duration_sec", "rollback"],
  "properties": {
    "iter": { "type": "number" },
    "timestamp": { "type": "string", "format": "date-time" },
    "duration_sec": { "type": "number" },
    "files_over_300": { "type": "number" },
    "any_count": { "type": "number" },
    "nonnull_count": { "type": "number" },
    "tests_passing": { "type": "number" },
    "tests_total": { "type": "number" },
    "tokens_used": { "type": "number" },
    "rollback": { "type": "boolean" },
    "reason": { "type": "string" }
  }
}
