{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph v2 tests.json",
  "type": "object",
  "required": ["summary", "features"],
  "properties": {
    "summary": {
      "type": "object",
      "required": ["total", "passing", "failing"],
      "properties": {
        "total": { "type": "number" },
        "passing": { "type": "number" },
        "failing": { "type": "number" }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "passing", "failing", "blocked"]
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "affected_packages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
